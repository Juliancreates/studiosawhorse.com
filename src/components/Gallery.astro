---
import { Image } from 'astro:assets';
import type { Piece } from '../data/furniture';

interface Props {
  pieces: Piece[];
  section: string;
}

const { pieces, section } = Astro.props;
---

<div class="gallery">
  {pieces.map((piece) => {
    const img = piece.images[0].src;
    const aspect = img.width / img.height;
    return (
    <figure style={`--aspect: ${aspect};`}>
      <a href={`/${section}/${piece.slug}`} class="gallery-link">
        <Image
          src={img}
          alt={piece.images[0].alt}
          width={1400}
          quality={88}
          loading="lazy"
          decoding="async"
          class="gallery-img"
        />
      </a>
      <figcaption>
        <p class="fig-title">{piece.title}</p>
        <p class="fig-meta">{piece.medium} · {piece.year}</p>
        <p class="fig-dims">{piece.dimensions}</p>
        {piece.price && <p class="fig-price">{piece.price}</p>}
      </figcaption>
    </figure>
    );
  })}
</div>

<style>
  .gallery {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    overflow-y: hidden;
    height: 100svh;
    padding: 0.75rem 1rem;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    position: relative;
  }


  .gallery::-webkit-scrollbar {
    display: none;
  }

  figure {
    flex: none;
    /* Width = assumed image height × aspect ratio */
    width: calc((100svh - 7.5rem) * var(--aspect));
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .gallery-link {
    display: block;
    height: calc(100svh - 7.5rem);
  }

  .gallery-link img {
    height: 100%;
    width: auto;
    display: block;
    object-fit: contain;
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  .gallery-img { cursor: pointer; }

  figcaption {
    flex-shrink: 0;
    padding-top: 0.75rem;
    padding-bottom: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    text-align: right;
  }

  .fig-title {
    font-family: 'Josefin Sans', sans-serif;
    font-size: 12px;
    font-weight: 700;
    color: #4d4d4d;
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  .fig-meta {
    font-family: 'Josefin Sans', sans-serif;
    font-size: 12px;
    color: #999;
  }

  .fig-dims {
    font-family: 'Josefin Sans', sans-serif;
    font-size: 12px;
    color: #bbb;
  }

  .fig-price {
    font-family: 'Courier Prime', monospace;
    font-size: 13px;
    font-weight: 700;
    color: #666;
    margin-top: 0.2rem;
  }

  @media (max-width: 767px) {
    .gallery {
      height: 70%;
      min-height: 0;
      padding: 0.75rem 1rem;
      margin: auto 0;
    }
    figure {
      width: calc((70svh - 7.5rem) * var(--aspect));
    }
    .gallery-link {
      height: calc(70svh - 7.5rem);
    }
  }

  @media (min-width: 768px) {
    .gallery {
      height: calc(100vh - 90px - 1.5rem);
      padding: 0.75rem 1rem;
    }
    figure {
      width: calc((100vh - 90px - 9rem) * var(--aspect));
    }
    .gallery-link {
      height: calc(100vh - 90px - 9rem);
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLImageElement>('.gallery-img').forEach((img) => {
    if (img.complete) {
      img.style.opacity = '1';
    } else {
      img.addEventListener('load', () => { img.style.opacity = '1'; });
    }
  });
</script>
